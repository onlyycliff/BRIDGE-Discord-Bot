# Bridge 2026 Bot Environment Configuration
# Copy this file to .env and fill in your actual values

# Discord Bot Token (required)
# Get from: https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# Discord Channel ID (required)
# The channel ID where polls will be posted
# Enable Developer Mode and right-click channel to copy ID
POLL_CHANNEL_ID=your_discord_channel_id_here

# Rules Channel Name (optional)
# Name of the channel where rules are posted
# Make sure the bot can access this channel
RULES_CHANNEL_NAME=📜｜rules

# Google Sheets ID (optional)
# If you want to sync poll data to Google Sheets
# This is the document ID from the URL: docs.google.com/spreadsheets/d/{GOOGLE_SHEETS_ID}/edit
# GOOGLE_SHEETS_ID=

# Flask Configuration (optional)
# Flask debug mode (set to False for production)
FLASK_ENV=development
FLASK_DEBUG=False

# Flask Secret Key (required for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Sessions will be invalidated on every restart if this is not set.
# FLASK_SECRET_KEY=your_secret_key_here

# PostgreSQL Database URL (required for Phase 2+)
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/bridge_dev
# For Railway: auto-injected into environment
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bridge_dev

# Application Settings
APP_HOST=localhost
APP_PORT=5000
